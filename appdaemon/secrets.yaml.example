# Copy this file to secrets.yaml and fill in your values.
# Find entity IDs in Home Assistant: Developer Tools > States
# secrets.yaml is gitignored.

# TP-Link Tapo T110 contact sensor entity ID
door_sensor: binary_sensor.front_door_contact

# Alexa notify service from the native Alexa Devices integration.
# Find it in: Settings > Devices & Services > Alexa Devices > your device > entities
# Use the _speak variant (notify.your_device_name_speak).
# The _announce variant exists but may not work on all devices.
alexa_announce_service: notify.your_device_name_speak

# Telegram notify service (uncomment telegram_notify_service in apps.yaml after setup)
# telegram_notify_service: notify.telegram
